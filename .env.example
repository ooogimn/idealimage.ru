# Скопируйте этот файл в .env и заполните своими значениями
# cp .env.example .env

# ============================================================================
# БАЗА ДАННЫХ
# DB_ENGINE=mysql      → локальная разработка / shared hosting
# DB_ENGINE=postgresql → VPS продакшен
# ============================================================================
DB_ENGINE=postgresql
DB_NAME=idealimage_db
DB_USER=idealimage_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# ============================================================================
# DJANGO
# ============================================================================
SECRET_KEY=your-secret-key-here-generate-with-python-secrets
DEBUG=False
DJANGO_ENV=production

# ============================================================================
# REDIS & CELERY
# ============================================================================
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================================================
# GIGACHAT API
# ============================================================================
Client_ID=your_client_id
Scope=GIGACHAT_API_PERS
GIGACHAT_API_KEY=your_api_key
GIGACHAT_MODEL=GigaChat

# ============================================================================
# TELEGRAM
# ============================================================================
BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=@your_channel
API_ID=your_api_id
API_HASH=your_api_hash
TITLE=your_title
SHORT_NAME=your_short_name

# ============================================================================
# EMAIL
# ============================================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
EMAIL_ADMIN=your_email@gmail.com

# ============================================================================
# YANDEX
# ============================================================================
YANDEX_WEBMASTER_TOKEN=your_token
YANDEX_WEBMASTER_USER_ID=your_user_id
YANDEX_WEBMASTER_HOST_ID=https:idealimage.ru:443
YANDEX_SHOP_ID=your_shop_id
YANDEX_SECRET_KEY=your_secret_key
YANDEX_TEST_MODE=False

# ============================================================================
# ПРОЧЕЕ
# ============================================================================
DISABLE_AI=false
INDEXNOW_KEY=your_key
BING_INDEXNOW_KEY=your_key
UNSPLASH_ACCESS_KEY=your_key
UNSPLASH_SECRET_KEY=your_key
PARSER_TIMEOUT=300
PARSER_MIN_IMAGE_WIDTH=400
PARSER_MIN_IMAGE_HEIGHT=300
PARSER_ENABLE_SELENIUM=false
